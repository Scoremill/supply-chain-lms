# Database Connection (Neon PostgreSQL)
DATABASE_URL='postgresql://USER:PASSWORD@ep-xxx.region.aws.neon.tech/DBNAME?sslmode=require'

# NextAuth Configuration
NEXTAUTH_SECRET=your-secret-key-generate-with-openssl-rand-base64-32
NEXT_PUBLIC_APP_URL=https://your-vercel-domain.vercel.app

# hCaptcha (keep existing values)
HCAPTCHA_SECRET_KEY=your-hcaptcha-secret-key
NEXT_PUBLIC_HCAPTCHA_SITE_KEY=your-hcaptcha-site-key

# Webhook for Help/Contact Form
WEBHOOK_URL=https://your-webhook-url
WEBHOOK_AUTH_HEADER_NAME=your-header-name
WEBHOOK_AUTH_HEADER_VALUE=your-header-value

# AWS S3 Storage (keep existing values)
AWS_REGION=us-west-2
AWS_BUCKET_NAME=your-bucket-name
AWS_FOLDER_PREFIX=your-folder-prefix/
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key

# OPTIONAL: Email (only if you add direct email features later)
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USER=your-email@gmail.com
# EMAIL_PASSWORD=your-app-password
# EMAIL_FROM=your-email@gmail.com
